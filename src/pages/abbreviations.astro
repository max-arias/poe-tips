---
import Layout from '../layouts/Layout.astro';
import PocketBase from 'pocketbase';

interface Abbreviation {
    acronym: string;
    definition: string;
    category: string;
}

let groupedAbbreviations: Record<string, Abbreviation[]> = {};
let categories: string[] = [];

try {
    const pb = new PocketBase('http://127.0.0.1:8090');
    const email = import.meta.env.POCKETBASE_ADMIN_EMAIL || process.env.POCKETBASE_ADMIN_EMAIL;
    const password = import.meta.env.POCKETBASE_ADMIN_PASSWORD || process.env.POCKETBASE_ADMIN_PASSWORD;
    
    if (email && password) {
        await pb.admins.authWithPassword(email, password);
    }

    const records = await pb.collection('abbreviations').getFullList({
        sort: 'category,acronym',
    });
    
    records.forEach((record: any) => {
        const abbr = {
            acronym: record.acronym,
            definition: record.definition,
            category: record.category
        };
        if (!groupedAbbreviations[abbr.category]) {
            groupedAbbreviations[abbr.category] = [];
        }
        groupedAbbreviations[abbr.category].push(abbr);
    });
    
    categories = Object.keys(groupedAbbreviations).sort();
    
} catch (e) {
    console.error('Failed to fetch abbreviations:', e);
}
---

<Layout title="PoE Abbreviations">
    <main class="container mx-auto px-4 py-8">
        <header class="text-center mb-12">
            <h1 class="text-4xl font-bold text-orange-500 mb-2">Abbreviations</h1>
            <p class="text-gray-400">Common acronyms and terms used in Path of Exile.</p>
            <a href="/" class="text-orange-400 hover:text-orange-300 underline mt-4 inline-block">Back to Tips</a>
        </header>
        
        <div class="max-w-4xl mx-auto space-y-8">
            {categories.map(category => (
                <section>
                    <h2 class="text-2xl font-bold text-orange-400 mb-4 border-b border-orange-900/50 pb-2">{category}</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        {groupedAbbreviations[category].map(abbr => (
                            <div class="bg-gray-800/50 p-4 rounded-lg border border-gray-700 hover:border-orange-500/50 transition-colors">
                                <div class="flex items-baseline justify-between">
                                    <span class="text-xl font-bold text-gray-200">{abbr.acronym}</span>
                                    <span class="text-xs text-gray-500 uppercase tracking-wider">{abbr.category}</span>
                                </div>
                                <p class="text-gray-400 mt-1">{abbr.definition}</p>
                            </div>
                        ))}
                    </div>
                </section>
            ))}
        </div>
    </main>
</Layout>
