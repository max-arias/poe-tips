---
import Layout from "../layouts/Layout.astro";
import { pb } from "../lib/pocketbase";

// Fetch abbreviations from PocketBase
let abbreviations = [];
try {
    abbreviations = await pb.collection("abbreviations").getFullList({
        sort: "acronym",
    });
} catch (e) {
    console.error("Failed to fetch abbreviations:", e);
}

// Generate JSON-LD
const jsonLd = {
    "@context": "https://schema.org",
    "@type": "DefinedTermSet",
    name: "Path of Exile Community Abbreviations",
    description:
        "A comprehensive list of common abbreviations and acronyms used by the Path of Exile community.",
    hasDefinedTerm: abbreviations.map((abbr) => ({
        "@type": "DefinedTerm",
        termCode: abbr.acronym,
        description: abbr.definition,
        inDefinedTermSet: "https://poetips.com/faqs", // Assuming this is the canonical URL
    })),
};
---

<Layout title="FAQs - PoE Tips">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <main class="container mx-auto px-4 py-8">
        <header class="mb-12 text-center">
            <h1 class="text-4xl font-bold text-orange-500 mb-2">
                Frequently Asked Questions
            </h1>
            <p class="text-gray-400">
                Common questions and community terminology.
            </p>
        </header>

        <section class="max-w-4xl mx-auto">
            <h2
                class="text-2xl font-bold text-white mb-6 border-b border-gray-700 pb-2"
            >
                Community Abbreviations
            </h2>

            <div class="bg-gray-800/30 rounded-lg border border-gray-700 p-6">
                {
                    abbreviations.length > 0 ? (
                        <dl class="space-y-4">
                            {abbreviations.map((abbr) => (
                                <div class="grid grid-cols-1 md:grid-cols-[120px_1fr] gap-2 md:gap-4 border-b border-gray-700/50 last:border-0 pb-4 last:pb-0">
                                    <dt class="font-mono text-orange-400 font-bold text-lg">
                                        {abbr.acronym}
                                    </dt>
                                    <dd class="text-gray-300">
                                        <p>{abbr.definition}</p>
                                        {abbr.category && (
                                            <span class="inline-block mt-1 text-xs text-gray-500 px-2 py-0.5 rounded bg-gray-900 border border-gray-800">
                                                {abbr.category}
                                            </span>
                                        )}
                                    </dd>
                                </div>
                            ))}
                        </dl>
                    ) : (
                        <p class="text-gray-400 italic">
                            No abbreviations found.
                        </p>
                    )
                }
            </div>
        </section>
    </main>
</Layout>
