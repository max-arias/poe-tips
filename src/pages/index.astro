---
import Layout from '../layouts/Layout.astro';
import TipsGrid from '../components/TipsGrid.tsx';
import { prepareTipsForSearch, type Tip } from '../lib/search';
import PocketBase from 'pocketbase';

// Fetch tips from PocketBase
let tips: Tip[] = [];
try {
    const pb = new PocketBase('http://127.0.0.1:8090');
    // Authenticate as admin for build process to ensure we can read everything including users
    const email = import.meta.env.POCKETBASE_ADMIN_EMAIL || process.env.POCKETBASE_ADMIN_EMAIL;
    const password = import.meta.env.POCKETBASE_ADMIN_PASSWORD || process.env.POCKETBASE_ADMIN_PASSWORD;
    
    if (email && password) {
        await pb.admins.authWithPassword(email, password);
    } else {
        console.warn('POCKETBASE_ADMIN_EMAIL or POCKETBASE_ADMIN_PASSWORD not set. Fetching public data only.');
    }

    const records = await pb.collection('tips').getList(1, 50, {
        // sort: '-created',
        expand: 'author',
    });
    
    tips = records.items.map(record => ({
        id: record.id,
        title: record.title,
        content: record.content,
        tags: record.tags || [],
        leagues: record.leagues || [],
        author: record.expand?.author?.name || record.expand?.author?.username || 'Unknown',
        vote_count: record.vote_count,
        patch_created: record.patch_created,
        last_verified_patch: record.last_verified_patch,
        is_broken: record.is_broken
    }));
} catch (e) {
    console.error('Failed to fetch tips:', e);
    // Fallback to empty or dummy data if needed, but for now just log
}

// Pre-calculate search tokens for the client
const preparedTips = prepareTipsForSearch(tips);
---

<Layout>
  <main class="container mx-auto px-4 py-8">
    <header class="text-center mb-12">
      <h1 class="text-4xl font-bold text-orange-500 mb-2">PoE Tips Grid</h1>
      <p class="text-gray-400">Community-driven knowledge for Path of Exile.</p>
    </header>

    <div class="max-w-4xl mx-auto">
      <TipsGrid client:load initialTips={preparedTips} />
    </div>
  </main>
</Layout>
